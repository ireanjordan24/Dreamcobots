{
  "tower": {
    "name": "DreamCo Control Tower",
    "version": "1.0.0",
    "owner": "ireanjordan24",
    "heartbeatIntervalSeconds": 30,
    "autoUpgradeEnabled": true,
    "autoUpgradeScheduleCron": "0 */6 * * *",
    "maxBots": 1000,
    "conflictResolutionStrategy": "theirs"
  },
  "github": {
    "owner": "ireanjordan24",
    "defaultBase": "main",
    "autoPREnabled": true,
    "autoPRTitle": "🤖 Auto-upgrade from DreamCo Control Tower",
    "autoPRBranch": "auto-update"
  },
  "payments": {
    "providers": ["stripe", "paypal", "square"],
    "currency": "usd"
  },
  "database": {
    "type": "json",
    "botsFile": "config/bots.json",
    "reposFile": "config/repos.json",
    "mongoUri": null
  },
  "deployment": {
    "backend": "heroku",
    "frontend": "vercel",
    "port": 8080
  }
}
