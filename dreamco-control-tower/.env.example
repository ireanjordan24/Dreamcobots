# DreamCo Control Tower — Environment Variables
# Copy this file to .env and fill in your values

# GitHub Integration (required for repo status, auto-PRs, and auto-upgrades)
GITHUB_TOKEN=
GITHUB_OWNER=ireanjordan24

# Server
PORT=4000

# Payment Providers (optional — dashboard works without these)
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# MongoDB (optional — uses in-memory/JSON registry by default)
MONGODB_URI=
