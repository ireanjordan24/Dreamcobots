{
  "version": "1.0.0",
  "platform": "DreamCo",
  "global_settings": {
    "max_concurrent_workflows": 25,
    "default_retry_attempts": 3,
    "notify_on_failure": true,
    "log_level": "info"
  },
  "workflows": [
    {
      "id": "fiverr",
      "name": "Fiverr Gig Automation",
      "file": "workflows/fiverr.json",
      "action": "fiverr_bot.run",
      "trigger": "schedule:every_6_hours",
      "enabled": true,
      "priority": 1
    },
    {
      "id": "real_estate",
      "name": "Real Estate Deal Pipeline",
      "file": "workflows/real_estate.json",
      "action": "real_estate_bot.run",
      "trigger": "schedule:daily",
      "enabled": true,
      "priority": 2
    },
    {
      "id": "grants",
      "name": "Government Grants Automation",
      "file": "workflows/grants.json",
      "action": "grants_bot.run",
      "trigger": "schedule:weekly",
      "enabled": true,
      "priority": 3
    },
    {
      "id": "legal_money",
      "name": "Legal Claims Automation",
      "file": "workflows/legal_money.json",
      "action": "legal_bot.run",
      "trigger": "schedule:weekly",
      "enabled": true,
      "priority": 4
    },
    {
      "id": "crypto",
      "name": "Crypto Trading Automation",
      "file": "workflows/crypto.json",
      "action": "crypto_bot.run",
      "trigger": "schedule:every_15_minutes",
      "enabled": true,
      "priority": 5
    }
  ]
}
