{
  "name": "dreamcobots",
  "version": "1.0.0",
  "description": "DreamCobots \u2014 Autonomous Money Operating System: AI-powered bots for lead generation, real estate, crypto, and more.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "echo 'Build complete'",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "apply-fix": "node apply-fix.js",
    "diagnose": "node diagnose.js",
    "deploy": "node deploy.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DreamCo-Technologies/Dreamcobots.git"
  },
  "author": "Irean Jordan",
  "license": "ISC",
  "dependencies": {
    "express": "^4.17.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
