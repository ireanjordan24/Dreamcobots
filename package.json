{
  "name": "dreamcobots",
  "version": "1.0.0",
  "description": "DreamCobots — Autonomous Money Operating System: AI-powered bots for lead generation, real estate, crypto, and more.",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "build": "node -e \"console.log('Build complete — no compile step required for this Node.js project.')\"",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/",
    "validate": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); console.log('package.json is valid JSON')\"",
    "apply-fix": "node apply-fix.js",
    "diagnose": "node diagnose.js",
    "deploy": "node deploy.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ireanjordan24/Dreamcobots.git"
  },
  "author": "Irean Jordan",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}