# DreamCobots — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── GitHub Integration ────────────────────────────────────────────────────────
# Personal access token with repo scope (used by control-tower and bots).
# In GitHub Actions this is provided automatically; set it manually for local
# runs or Replit via Secrets.
GITHUB_TOKEN=your_github_token_here

# ── OpenAI / AI provider keys ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# AI Integrations module key (maps to AI_INTEGRATIONS_OPENAI_API_KEY secret in
# GitHub Actions and Replit Secrets).  Can be the same value as OPENAI_API_KEY
# or a separate key scoped to AI-integration tasks only.
AI_INTEGRATIONS_OPENAI_API_KEY=your_ai_integrations_openai_api_key_here

# Custom OpenAI-compatible endpoint (leave empty to use the default
# https://api.openai.com/v1).  Example for a local proxy or model farm:
#   OPENAI_ENDPOINT=http://localhost:1106/modelfarm/openai
OPENAI_ENDPOINT=

# ── Application settings ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_this_to_a_random_secret_string

# ── Database / cache ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# ── Bot-specific keys (fill in only the bots you use) ─────────────────────────
SELENIUM_HEADLESS=true
INDEED_EMAIL=
INDEED_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Government Contract Bot ───────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Crypto Bot ───────────────────────────────────────────────────────────────
CRYPTO_EXCHANGE_API_KEY=
CRYPTO_EXCHANGE_API_SECRET=

# ── Real Estate Bot ───────────────────────────────────────────────────────────
ZILLOW_API_KEY=
MLS_API_KEY=

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_API_KEY=

# ── Web scraping ─────────────────────────────────────────────────────────────
SCRAPER_API_KEY=

# ── Runtime flags (DreamCo Autonomous OS) ────────────────────────────────────
# Set to "false" to enable live API calls (requires keys above)
SIMULATION_MODE=true
MONEY_LOOP_CYCLES=1
SCALE_THRESHOLD_USD=1000.0
MAINTAIN_THRESHOLD_USD=100.0
