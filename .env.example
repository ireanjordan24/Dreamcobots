# DreamCobots — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── OpenAI / AI provider keys ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Application settings ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_this_to_a_random_secret_string

# ── Database / cache ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# ── Bot-specific keys (fill in only the bots you use) ─────────────────────────
SELENIUM_HEADLESS=true
INDEED_EMAIL=
INDEED_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Government Contract Bot ───────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Crypto Bot ───────────────────────────────────────────────────────────────
CRYPTO_EXCHANGE_API_KEY=
CRYPTO_EXCHANGE_API_SECRET=

# ── Real Estate Bot ───────────────────────────────────────────────────────────
ZILLOW_API_KEY=
MLS_API_KEY=

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Obtain keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development and live keys (sk_live_...) in
# production. Store live keys in GitHub Secrets — never commit them here.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Obtain from https://dashboard.stripe.com/webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
