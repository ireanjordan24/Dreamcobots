# DreamCobots — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── OpenAI / AI provider keys ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Application settings ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_this_to_a_random_secret_string

# ── Database / cache ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# ── Bot-specific keys (fill in only the bots you use) ─────────────────────────
SELENIUM_HEADLESS=true
INDEED_EMAIL=
INDEED_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Government Contract Bot ───────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Crypto Bot ───────────────────────────────────────────────────────────────
CRYPTO_EXCHANGE_API_KEY=
CRYPTO_EXCHANGE_API_SECRET=

# ── Real Estate Bot ───────────────────────────────────────────────────────────
ZILLOW_API_KEY=
MLS_API_KEY=

# ── Stripe (Monetization) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ── Email (Campaigns) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dreamco.ai

# ── Affiliate Networks ─────────────────────────────────────────────────────────
AMAZON_ASSOCIATE_TAG=
CLICKBANK_API_KEY=
SHAREASALE_AFFILIATE_ID=

# ── Cron Settings ─────────────────────────────────────────────────────────────
CRON_ENABLED=true
BOT_RUN_INTERVAL_MS=3600000
LEAD_SCRAPE_INTERVAL_MS=21600000
EMAIL_SEND_INTERVAL_MS=86400000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dreamco
DB_POOL_SIZE=10
