# DreamCobots — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── OpenAI / AI provider keys ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Application settings ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_this_to_a_random_secret_string

# ── Database / cache ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# ── Bot-specific keys (fill in only the bots you use) ─────────────────────────
SELENIUM_HEADLESS=true
INDEED_EMAIL=
INDEED_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Government Contract Bot ───────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Crypto Bot ───────────────────────────────────────────────────────────────
CRYPTO_EXCHANGE_API_KEY=
CRYPTO_EXCHANGE_API_SECRET=

# ── Real Estate Bot ───────────────────────────────────────────────────────────
ZILLOW_API_KEY=
MLS_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Your Stripe Publishable Key (safe to expose to front-end clients)
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# Your Stripe Secret Key (keep this secret — never commit it)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# Webhook signing secret (Stripe Dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
