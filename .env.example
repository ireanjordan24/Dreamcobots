# DreamCobots — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── OpenAI / AI provider keys ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Application settings ──────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change_this_to_a_random_secret_string

# ── Database / cache ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Monitoring / Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# ── Bot-specific keys (fill in only the bots you use) ─────────────────────────
SELENIUM_HEADLESS=true
INDEED_EMAIL=
INDEED_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Government Contract Bot ───────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Crypto Bot ───────────────────────────────────────────────────────────────
CRYPTO_EXCHANGE_API_KEY=
CRYPTO_EXCHANGE_API_SECRET=

# ── Real Estate Bot ───────────────────────────────────────────────────────────
ZILLOW_API_KEY=
MLS_API_KEY=

# ── Stripe Integration (Dreamcobots, LLC) ────────────────────────────────────
# Used by all bots: Lead Gen, SaaS, Real Estate, Car Flipping, DreamCo Payments
# Keys are available at https://dashboard.stripe.com/apikeys
#
# Publishable key — safe to expose in frontend/client-side code
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE
#
# Secret key — KEEP PRIVATE, server-side only, never commit to source control
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
#
# Webhook signing secret — from Dashboard > Developers > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET_HERE
#
# Internal DreamCo Stripe reference key (legacy, used by dreamco_payments bot)
DREAMCO_STRIPE_KEY=sk_test_placeholder_dreamco_stripe_key
#
# Base URL for Stripe success/cancel redirects
APP_BASE_URL=https://dreamcobots.com
