# DreamCo LeadGenBot Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Stripe Integration
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Subscription Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_STARTER_PLAN_ID
STRIPE_PRICE_PRO=price_PRO_PLAN_ID
STRIPE_PRICE_AGENCY=price_AGENCY_PLAN_ID

# Scraping Configuration
SCRAPE_CONCURRENCY=5
MAX_LEADS_PER_SCRAPE=200

# DreamCo Branding
DREAMCO_WATERMARK=true
