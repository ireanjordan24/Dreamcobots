run = "python main.py"
language = "python3"

# ── Resource target: 2 vCPUs / 4 GiB RAM ──────────────────────────────────
# These values are informational hints; actual allocation is controlled by
# your Replit plan.  The project is designed to run comfortably within
# Replit's 2 vCPU / 4 GiB Boost configuration.

[nix]
channel = "stable-22_11"

# ── Environment variables injected into every run ─────────────────────────
# Non-sensitive defaults only.  Set REAL secrets in Replit Secrets (the 🔒
# icon in the sidebar) — never put actual credentials here.
[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"
SIMULATION_MODE = "true"
LOG_LEVEL = "INFO"
# Required secrets (add values in Replit Secrets, NOT here):
#   AI_INTEGRATIONS_OPENAI_API_KEY  — OpenAI key for the AI-integrations bot
#   OPENAI_API_KEY                  — General OpenAI API key
#   OPENAI_ENDPOINT                 — Custom OpenAI-compatible endpoint URL (optional)
#   GITHUB_TOKEN                    — GitHub personal-access token (repo scope)
#   STRIPE_API_KEY                  — Stripe secret key
#   ZILLOW_API_KEY                  — Zillow API key
#   SCRAPER_API_KEY                 — Web scraper API key

[packager]
language = "python3"

  [packager.features]
  packageSearch = true
  guessImports = true
  enabledForHosting = false

[interpreter]
  [interpreter.command]
  args = ["python3", "$file"]

[unitTest]
language = "python3"

[debugger]
support = true

  [debugger.interactive]
  transport = "localhost:0"
  startCommand = ["dap-python", "main.py"]

    [debugger.interactive.integratedAdapter]
    dapTcpAddress = "localhost:0"

    [debugger.interactive.initializeMessage]
    command = "initialize"
    type = "request"

      [debugger.interactive.initializeMessage.arguments]
      adapterID = "debugpy"
      clientID = "replit"
      clientName = "replit.com"
      columnsStartAt1 = true
      linesStartAt1 = true
      locale = "en-us"
      pathFormat = "path"
      supportsInvalidatedEvent = true
      supportsProgressReporting = true
      supportsRunInTerminalRequest = true
      supportsVariablePaging = true
      supportsVariableType = true

    [debugger.interactive.launchMessage]
    command = "attach"
    type = "request"

      [debugger.interactive.launchMessage.arguments]
      logging = {}
